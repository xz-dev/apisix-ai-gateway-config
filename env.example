# Main logical provider deployment pool. You can use either numbered variables or comma-separated lists.
OLLAMA_CLOUD_KEY_1=replace-me
# Optional additional same-priority deployments for ai-proxy-multi round-robin/account fallback.
# OLLAMA_CLOUD_KEY_2=replace-me
# OLLAMA_CLOUD_KEYS=replace-me-a,replace-me-b,replace-me-c

DEEPSEEK_API_KEY=replace-me
XAI_API_KEY=replace-me

# SiliconFlow CN logical provider. Also supports SILICONFLOW_CN_API_KEYS.
SILICONFLOW_CN_API_KEY=replace-me
