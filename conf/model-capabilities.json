{
  "version": 1,
  "description": "Fallback Hermes capability registry for APISIX routes. Use only when upstream provider APIs do not expose capability metadata. Ollama Cloud is intentionally excluded because its native /api/show endpoint exposes authoritative capabilities.",
  "models": {
    "deepseek/deepseek-v4-flash": {
      "context_window": 1000000,
      "max_output_tokens": 8192,
      "supports_tools": true,
      "supports_vision": false,
      "reasoning": {
        "enabled": true,
        "param": "reasoning_effort",
        "efforts": ["low", "medium", "high", "xhigh", "max"]
      }
    },
    "deepseek/deepseek-v4-pro": {
      "context_window": 1000000,
      "max_output_tokens": 8192,
