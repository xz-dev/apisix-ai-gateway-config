        "param": "reasoning_effort",
        "efforts": ["low", "medium", "high", "xhigh", "max"]
      }
    },
    "xai/grok-4.3": {
      "context_window": 1000000,
      "max_output_tokens": 1000000,
      "supports_tools": true,
      "supports_vision": true,
      "reasoning": {
        "enabled": true,
        "param": "reasoning_effort",
