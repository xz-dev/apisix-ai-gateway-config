# Main model pool. You can use either numbered variables or comma-separated lists.
OLLAMA_CLOUD_KEY_1=replace-me
# Optional additional same-priority primary keys for ai-proxy-multi round-robin/failover.
# OLLAMA_CLOUD_KEY_2=replace-me
# OLLAMA_CLOUD_KEYS=replace-me-a,replace-me-b,replace-me-c

# Optional lower-priority fallback tier, tried after primary deployments are exhausted.
# OLLAMA_CLOUD_FALLBACK_KEY_1=replace-me
# OLLAMA_CLOUD_FALLBACK_KEYS=replace-me-a,replace-me-b

DEEPSEEK_API_KEY=replace-me
XAI_API_KEY=replace-me

# Optional overrides.
# OLLAMA_CLOUD_PUBLIC_MODEL=ollama/glm-5.1
# OLLAMA_CLOUD_ROUTED_MODEL=glm-5.1
# OLLAMA_CLOUD_ENDPOINT=https://ollama.com/v1/chat/completions
# APISIX_AI_GATEWAY_TIMEOUT_MS=30000

# Vision model pool. Also supports SILICONFLOW_CN_API_KEYS and
# SILICONFLOW_CN_FALLBACK_API_KEY_N / SILICONFLOW_CN_FALLBACK_API_KEYS.
SILICONFLOW_CN_API_KEY=replace-me
# SILICONFLOW_CN_PUBLIC_MODEL=siliconflow-cn/Qwen/Qwen3.6-35B-A3B
# SILICONFLOW_CN_ROUTED_MODEL=Qwen/Qwen3.6-35B-A3B
# SILICONFLOW_CN_ENDPOINT=https://api.siliconflow.cn/v1/chat/completions
